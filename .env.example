# ===== MITS 패널 설정 =====
# 실제 배포 시 .env 는 GitHub Actions가 시크릿으로 자동 생성합니다.
# 로컬 개발/수동 설치 시 이 파일을 복사해서 .env 로 사용하세요.

# 패널 바인딩 — 보안상 localhost 고정 권장(접속은 SSH 터널)
PANEL_HOST=127.0.0.1
PANEL_PORT=3000

# 패널 로그인 비밀번호 (반드시 변경) — 관리자(전체 권한)
PANEL_PASSWORD=change-me

# (선택) 뷰어 비밀번호 — 친구에게 읽기전용 공유. 비우면 뷰어 비활성
PANEL_VIEWER_PASSWORD=

# 세션 시크릿 (랜덤 권장: openssl rand -hex 32)
SESSION_SECRET=change-me-too

# mc1/mc2 세션과 같은 tmux 소켓 공유 (변경 불필요)
TMUX_TMPDIR=/tmp

# (선택) 자동 백업: N시간마다 월드 백업. 0=끄기, 보관 개수=BACKUP_KEEP
AUTO_BACKUP_HOURS=0
BACKUP_KEEP=10

# (선택) 영속 데이터 디렉터리 — 예약/매크로/메트릭/게임상태 저장(배포 git reset 영향 밖). 기본 ~/mits-data
# DATA_DIR=/home/ubuntu/mits-data
# (선택) HTTPS 프록시(tailscale serve 등) 뒤에서만 1 로. http(로컬/SSH터널)에선 비워둘 것.
# PANEL_SECURE_COOKIE=1
# (선택) 리소스 메트릭 수집 간격(초)/보존(시간). 기본 15 / 24
# METRICS_INTERVAL_SEC=15
# METRICS_RETAIN_HOURS=24

# ===== (선택) 서버 구성 오버라이드 — 기본값은 GSMSV 실측 구성 =====
# S1_NAME=1번 서버
# S1_SESSION=mc1
# S1_DIR=/home/ubuntu/server1
# S1_PORT=25565
# S2_NAME=2번 서버
# S2_SESSION=mc2
# S2_DIR=/home/ubuntu/server2
# S2_PORT=25566
# JAVA_XMS=3G
# JAVA_XMX=3G
# PAPER_JAR=paper.jar
# CONSOLE_LINES=250
